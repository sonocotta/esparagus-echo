{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "ESPHome: Build Current File (Stable)",
			"type": "shell",
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"-v",
				"${fileDirname}:/config",
				"-v",
				"${workspaceFolder}/firmware/esphome/packages:/config/packages",
				"-v",
				"${workspaceFolder}/firmware/esphome/secrets/secrets.yaml:/config/secrets.yaml",
				"-v",
				"${workspaceFolder}/.esphome-cache:/cache",
				"-e",
				"PLATFORMIO_BUILD_CACHE_DIR=/cache/.pio-cache",
				"-it",
				"esphome/esphome:latest",
				"compile",
				"/config/${fileBasename}"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "ESPHome: Build Current File (Develop)",
			"type": "shell",
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"-v",
				"${fileDirname}:/config",
				"-v",
				"${workspaceFolder}/firmware/esphome/packages:/config/packages",
				"-v",
				"${workspaceFolder}/firmware/esphome/secrets/secrets.yaml:/config/secrets.yaml",
				"-v",
				"${workspaceFolder}/.esphome-cache:/cache",
				"-e",
				"PLATFORMIO_BUILD_CACHE_DIR=/cache/.pio-cache",
				"-it",
				"esphome/esphome:dev",
				"compile",
				"/config/${fileBasename}"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "ESPHome: Build and Upload OTA (Stable)",
			"type": "shell",
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"--network=host",
				"-v",
				"${fileDirname}:/config",
				"-v",
				"${workspaceFolder}/firmware/esphome/packages:/config/packages",
				"-v",
				"${workspaceFolder}/firmware/esphome/secrets/secrets.yaml:/config/secrets.yaml",
				"-v",
				"${workspaceFolder}/.esphome-cache:/cache",
				"-e",
				"PLATFORMIO_BUILD_CACHE_DIR=/cache/.pio-cache",
				"-it",
				"esphome/esphome:latest",
				"run",
				"/config/${fileBasename}",
				"--device",
				"OTA"
			],
			"problemMatcher": []
		},
		{
			"label": "ESPHome: Build and Upload OTA (Develop)",
			"type": "shell",
			"command": "docker",
			"args": [
				"run",
				"--rm",
				"--network=host",
				"-v",
				"${fileDirname}:/config",
				"-v",
				"${workspaceFolder}/firmware/esphome/packages:/config/packages",
				"-v",
				"${workspaceFolder}/firmware/esphome/secrets/secrets.yaml:/config/secrets.yaml",
				"-v",
				"${workspaceFolder}/.esphome-cache:/cache",
				"-e",
				"PLATFORMIO_BUILD_CACHE_DIR=/cache/.pio-cache",
				"-it",
				"esphome/esphome:dev",
				"run",
				"/config/${fileBasename}",
				"--device",
				"OTA"
			],
			"problemMatcher": []
		}
	]
}